# Server
PORT=4000
CORS_ORIGIN=https://owsbountybot.shelmail.xyz

# Admin token for resetting bounty programs (leave empty to prevent resets)
BOUNTYBOT_ADMIN_TOKEN=

# Database
BOUNTYBOT_DB_PATH=data/bountybot.db

# Demo delay in ms (set to 0 for tests)
BOUNTYBOT_EVALUATION_DELAY_MS=1500

# OWS vault path (default: ~/.ows/wallets)
OWS_VAULT_PATH=
